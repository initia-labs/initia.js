{
  "name": "@initia/ledger-key",
  "version": "2.0.0-rc.0",
  "description": "Ledger hardware wallet support for initia.js@v2",
  "license": "Apache-2.0",
  "author": "Initia Foundation",
  "repository": {
    "type": "git",
    "url": "https://github.com/initia-labs/initia.js",
    "directory": "packages/ledger-key"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "LEDGER_TEST=true vitest run",
    "test:integration:eth": "LEDGER_TEST=true vitest run -t 'Ethereum'",
    "test:integration:cosmos": "LEDGER_TEST=true vitest run -t 'Cosmos'"
  },
  "peerDependencies": {
    "@initia/initia.js": "next"
  },
  "dependencies": {
    "@ledgerhq/hw-app-eth": "^7.6.1",
    "@ledgerhq/hw-transport": "^6.34.1",
    "@noble/curves": "^2.0.0",
    "@noble/hashes": "^2.0.0",
    "@zondax/ledger-cosmos-js": "^4.0.0"
  },
  "devDependencies": {
    "@ledgerhq/hw-transport-mocker": "^6.33.1",
    "@ledgerhq/hw-transport-node-hid": "^6.32.1",
    "typescript": "^5.0.0",
    "vitest": "^4.1.2"
  }
}
